services:
  doorman:
    image: ghcr.io/tiraelsedai/clubdoorman:latest
    container_name: doorman
    environment:
      - TZ=Europe/Moscow
      - DOORMAN_CLUB_SERVICE_TOKEN=${DOORMAN_CLUB_SERVICE_TOKEN}
      - DOORMAN_BOT_API=${DOORMAN_BOT_API}
      - DOORMAN_ADMIN_CHAT=${DOORMAN_ADMIN_CHAT}
      - DOORMAN_BLACKLIST_AUTOBAN_DISABLE=${DOORMAN_BLACKLIST_AUTOBAN_DISABLE}
      - DOORMAN_LOW_CONFIDENCE_HAM_ENABLE=${DOORMAN_LOW_CONFIDENCE_HAM_ENABLE}
      - DOORMAN_CLICKHOUSE__ENABLED=${DOORMAN_CLICKHOUSE__ENABLED:-false}
      - DOORMAN_CLICKHOUSE__URL=${DOORMAN_CLICKHOUSE__URL:-http://clickhouse:8123}
      - DOORMAN_CLICKHOUSE__DATABASE=${DOORMAN_CLICKHOUSE__DATABASE:-tg}
      - DOORMAN_CLICKHOUSE__RAW_TABLE=${DOORMAN_CLICKHOUSE__RAW_TABLE:-tg.messages_raw}
      - DOORMAN_CLICKHOUSE__INGEST_SOURCE=${DOORMAN_CLICKHOUSE__INGEST_SOURCE:-live}
      - DOORMAN_CLICKHOUSE__BATCH_SIZE=${DOORMAN_CLICKHOUSE__BATCH_SIZE:-500}
      - DOORMAN_CLICKHOUSE__FLUSH_MS=${DOORMAN_CLICKHOUSE__FLUSH_MS:-500}
      - DOORMAN_CLICKHOUSE__CHANNEL_CAPACITY=${DOORMAN_CLICKHOUSE__CHANNEL_CAPACITY:-5000}
      - DOORMAN_CLICKHOUSE__MAX_RETRY=${DOORMAN_CLICKHOUSE__MAX_RETRY:-3}
      - DOORMAN_CLICKHOUSE__RETRY_DELAY=${DOORMAN_CLICKHOUSE__RETRY_DELAY:-2}
      - DOORMAN_CLICKHOUSE__HTTP_TIMEOUT=${DOORMAN_CLICKHOUSE__HTTP_TIMEOUT:-10}
    volumes:
      - ./ClubDoorman/data:/app/data
    restart: unless-stopped
