#!/home/kpblc/projects/ClubDoorman/scripts/testkit-sql-indexer/venv/bin/python3
import sys
import os

# Активируем виртуальное окружение
venv_path = "/home/kpblc/projects/ClubDoorman/scripts/testkit-sql-indexer/venv"
if os.path.exists(venv_path):
    # Добавляем путь к site-packages виртуального окружения
    site_packages = os.path.join(venv_path, "lib", "python3.11", "site-packages")
    if os.path.exists(site_packages):
        sys.path.insert(0, site_packages)

# Добавляем путь к модулям
script_dir = os.path.dirname(os.path.abspath(__file__))
project_dir = os.path.dirname(script_dir)
sys.path.insert(0, project_dir)

from tk_fastmcp_server import TestKitFastMCPServer

if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(description="TestKit MCP Server")
    parser.add_argument("--db-path", 
                       default=os.environ.get("TESTKIT_DB_PATH", "testkit_index.db"),
                       help="Database file path")
    
    args = parser.parse_args()
    
    server = TestKitFastMCPServer(args.db_path)
    server.run()
