# Основные настройки бота
DOORMAN_BOT_API=your-bot-token-here
DOORMAN_ADMIN_CHAT=your-admin-chat-id

# AI анализ (OpenRouter API)
DOORMAN_OPENROUTER_API=your-openrouter-api-key

# Система мимикрии
DOORMAN_SUSPICIOUS_DETECTION_ENABLE=true
DOORMAN_MIMICRY_THRESHOLD=0.7
DOORMAN_SUSPICIOUS_TO_APPROVED_COUNT=3

# Дополнительные настройки
DOORMAN_CLUB_SERVICE_TOKEN=your-club-service-token
DOORMAN_APPROVE_BUTTON=true
DOORMAN_USE_NEW_APPROVAL_SYSTEM=false

# Настройки модерации
DOORMAN_BLACKLIST_AUTOBAN_DISABLE=false
DOORMAN_CHANNELS_AUTOBAN_DISABLE=false
DOORMAN_LOOKALIKE_AUTOBAN_DISABLE=false
DOORMAN_BUTTON_AUTOBAN_DISABLE=false
DOORMAN_HIGH_CONFIDENCE_AUTOBAN_DISABLE=false

# Автоматический бан пользователей, входящих через папки (true/false)
DOORMAN_BAN_FOLDER_INVITE_USERS=false

# AI включенные чаты (через запятую)
DOORMAN_AI_ENABLED_CHATS=

# Отключенные чаты (через запятую)
DOORMAN_DISABLED_CHATS=

# Whitelist чатов (через запятую)
DOORMAN_WHITELIST=

# Группы без рекламы VPN (через запятую)
NO_VPN_AD_GROUPS= 

# Группы с отключенной капчей (через запятую)
DOORMAN_NO_CAPTCHA_GROUPS=

# Удаление пересланных сообщений от новичков (true/false)
DOORMAN_DELETE_FORWARDED_MESSAGES=false

# Фильтр ссылок (true/false)
DOORMAN_TEXT_MENTION_FILTER_ENABLE=true

# Каскадные проверки ML -> AI (true/false)
DOORMAN_LOW_CONFIDENCE_HAM_ENABLE=true

# Количество повторных нарушений перед баном (0 = отключено)
DOORMAN_ML_VIOLATIONS_BEFORE_BAN=4
DOORMAN_STOP_WORDS_VIOLATIONS_BEFORE_BAN=3
DOORMAN_EMOJI_VIOLATIONS_BEFORE_BAN=2
DOORMAN_LOOKALIKE_VIOLATIONS_BEFORE_BAN=2
DOORMAN_CAPTCHA_VIOLATIONS_BEFORE_BAN=3 

# --- RabbitMQ ingestion (optional) ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
DOORMAN_RABBITMQ__ENABLED=false
DOORMAN_RABBITMQ__URI=amqp://guest:guest@rabbitmq:5672/
DOORMAN_RABBITMQ__INPUT_QUEUE=spampyre.pipeline.input
DOORMAN_RABBITMQ__DLQ=spampyre.pipeline.dlq
DOORMAN_RABBITMQ__PREFETCH=50
DOORMAN_RABBITMQ__PUBLISH_TIMEOUT_SECONDS=5
DOORMAN_RABBITMQ__EVENT_EXCHANGE=spampyre.events

# --- Logging ---
# Базовый уровень логов приложения (Verbose|Debug|Information|Warning|Error|Fatal) - применяется если не заданы более конкретные
DOORMAN_LOG_LEVEL=Information
# Минимальный уровень для консоли (если не задан - используется DOORMAN_LOG_LEVEL)
#DOORMAN_LOG_LEVEL_CONSOLE=Information
# Минимальный уровень для файловых логов (если не задан - используется DOORMAN_LOG_LEVEL)
#DOORMAN_LOG_LEVEL_FILE=Debug
# Включить детальные TRACE (принудительно Verbose только для файловых логов)
DOORMAN_TRACE_ENABLE=false